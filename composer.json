{
    "name": "vladosik/variant2",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "scripts": {
        "lint": "vendor/bin/phpcs --standard=PSR12 src/",
        "analyze": "vendor/bin/phpstan analyse src --level 5"
    }
}
